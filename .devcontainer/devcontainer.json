{
  "name": "${containerEnv:PROJECT_NAME:dotNet Project}",
  "dockerComposeFile": [
    "docker-compose.yml",
    "docker-compose.override.yml"
  ],
  "service": "gateway",
  "workspaceFolder": "/workspaces/${containerEnv:PROJECT_NAME:gateway}",
  "initializeCommand": [
    "bash",
    "-lc",
    "cid=$(docker ps -aq --filter name=^${localEnv:PROJECT_NAME}$); if [ -n \"$cid\" ]; then docker rm -f ${localEnv:PROJECT_NAME}; fi"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        // C# and .NET extensions
        "ms-dotnettools.csharp",
        "ms-dotnettools.csdevkit",
        "editorconfig.editorconfig",
        "formulahendry.dotnet-test-explorer",
        "jmrog.vscode-nuget-package-manager",
        "kreativ-software.csharpextensions",
        "ms-dotnettools.blazorwasm-companion",
        "k--kato.docomment",
        // Infrastructure extensions
        "redhat.vscode-yaml",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        "ms-azuretools.vscode-docker",
        "esbenp.prettier-vscode",
        "eamodio.gitlens",
        // AI assistance extensions
        "sourcegraph.cody-ai",
        "anthropic.claude-dev",
        "anthropic.claude-code",
        "openai.chatgpt",
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "Google.geminicodeassist",
        "google.gemini-cli-vscode-ide-companion"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh"
      }
    }
  },
  "forwardPorts": [5228, 7149, 1455],
  "postCreateCommand": "cd src && dotnet restore",
  "containerEnv": {
    "SSH_AUTH_SOCK": "",
    "DISABLE_AUTO_SSH_AGENT": "1"
  },
  "terminal.integrated.profiles.linux": {
  "zsh": {
    "path": "/bin/zsh",
    "args": ["-l"]
  },
  "Codex": {
    "path": "/bin/zsh",
    "args": ["-c", "codex cmd; exec zsh"]
  },
  "Claude Code": {
    "path": "/bin/zsh",
    "args": ["-c", "claude cmd; exec zsh"]
  }
  },
  "terminal.integrated.defaultProfile.linux": "zsh",
  "remoteUser": "${localEnv:USER:vscode}"
}
